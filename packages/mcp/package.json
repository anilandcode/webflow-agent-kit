{
  "name": "@webflow-agent-kit/mcp",
  "version": "0.1.0-beta.1",
  "description": "Standalone MCP server exposing all Webflow agent tools",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "webflow-mcp": "dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "@webflow-agent-kit/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0"
  }
}

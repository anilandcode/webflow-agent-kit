{
  "name": "@webflow-agent-kit/langchain",
  "version": "0.0.1",
  "description": "LangChain DynamicStructuredTool adapter for webflow-agent-kit",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@webflow-agent-kit/core": "workspace:*"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "tsup": "^8.3.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "zod": ">=3.23.0"
  }
}

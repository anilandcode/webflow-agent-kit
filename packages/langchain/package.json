{
  "name": "@webflow-agent-kit/langchain",
  "version": "0.0.1",
  "description": "LangChain DynamicStructuredTool adapter for webflow-agent-kit — BETA",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@webflow-agent-kit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "zod": ">=3.23.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
